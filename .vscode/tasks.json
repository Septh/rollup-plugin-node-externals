{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "clean",
      "type": "npm",
      "script": "clean",
      "presentation": {
        "reveal": "silent",
        "clear": true
      }
    },
    {
      "label": "npm: lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": "$eslint-stylish"
    },
    {
      "label": "tsc: watch - tsconfig.build.json",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "type": "typescript",
      "tsconfig": "tsconfig.build.json",
      "option": "watch",
      "problemMatcher": [
        "$tsc-watch"
      ],
      "presentation": {
        "echo": true,
        "reveal": "silent",
      },
      "dependsOn": [ "clean" ],
      "dependsOrder": "sequence",
      "runOptions": {
        // "runOn": "folderOpen"
      }
    }
  ]
}
